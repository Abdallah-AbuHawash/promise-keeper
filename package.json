{
  "name": "promise-keeper",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Telegram + Slack + ClickUp agent that captures the promises support engineers make to customers and turns them into tracked tasks.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "sweep": "tsx src/scripts/run-sweep.ts",
    "setup:webhook": "tsx src/scripts/clickup-webhook.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@hono/node-server": "^2.0.4",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "grammy": "^1.43.0",
    "hono": "^4.12.25",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.0",
    "prettier": "^3.6.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
