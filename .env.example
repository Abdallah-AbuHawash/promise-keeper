# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
# Model for commitment extraction. Default claude-opus-4-8.
# claude-haiku-4-5 is cheaper/faster and fine for this task (adaptive thinking
# is auto-disabled for Haiku, which doesn't support it).
ANTHROPIC_MODEL=claude-opus-4-8

# ---- Telegram ----
# Create a bot via @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ---- Slack (Web API + Events API) ----
# From your Slack app. Signing secret verifies inbound Events API requests.
SLACK_SIGNING_SECRET=...
# Token used for Web API reads. A user token (xoxp-...) or bot token (xoxb-...)
# with scopes: channels:history, groups:history, reactions:read, users:read.
SLACK_BOT_TOKEN=xoxp-...
# Comma-separated channel IDs the agent watches (e.g. C0123ABC,C0456DEF).
SLACK_WATCH_CHANNELS=C0123ABC
# Emoji name (no colons) that an engineer reacts with to flag a promise.
SLACK_TRIGGER_EMOJI=pushpin

# ---- ClickUp REST API ----
# Personal API token (Settings → Apps → API Token). Starts with pk_.
CLICKUP_TOKEN=pk_...
# Default ClickUp list new tasks are created in.
CLICKUP_LIST_ID=901234567

# ---- Runtime ----
# Port the Hono webhook server listens on.
PORT=3000
# Public base URL (e.g. an ngrok URL) — used only for logging the Slack events path.
PUBLIC_URL=http://localhost:3000
# Path to the SQLite database file.
DATABASE_PATH=./data/promise-keeper.db
# Cron expression for the Slack sweep (default: every 5 minutes — demo-friendly).
SWEEP_CRON=*/5 * * * *
# Cron expression for reminder checks (default: every 15 minutes).
REMINDER_CRON=*/15 * * * *
# Cron expression for the daily digest (default: 08:00 daily).
DIGEST_CRON=0 8 * * *
# IANA timezone used for cron schedules and due-date reasoning.
TZ=Europe/Berlin
# Minimum confidence (0-1) required before a swept (Lane B) promise is surfaced.
SWEEP_MIN_CONFIDENCE=0.5
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info
